{
  "model_name": "helmet-detector",
  "version": "v3",
  "task": "object-detection",
  "architecture": "yolo26s",
  "base_weights": "yolo26s.pt (COCO pretrained)",
  "training_date": "2026-07-04",
  "trained_by": "argha",
  "git_commit": "a1b2c3d",
  "dataset": {
    "name": "site-ppe",
    "version": "v2",
    "location": "s3://company-datasets/site-ppe-v2/",
    "num_train_images": 4200,
    "num_val_images": 600,
    "classes": ["helmet", "no-helmet", "vest"]
  },
  "hyperparameters": {
    "epochs": 100,
    "batch_size": 16,
    "img_size": 640,
    "lr": 0.001,
    "seed": 42
  },
  "metrics": {
    "eval_set": "site-ppe-v2/val",
    "mAP50-95": 0.612,
    "mAP50": 0.874,
    "precision": 0.89,
    "recall": 0.85,
    "latency_ms_tensorrt_int8_orin": 8.4
  },
  "exports": ["exported/helmet-det-v3.pt", "onnx/helmet-det-v3.onnx", "tensorrt/helmet-det-v3-int8.engine"],
  "notes": "Misses helmets at extreme top-down angles; see docs/known-limitations.md"
}
