# ── Data ────────────────────────────────────────────────
DATA_RAW_DIR=data/raw/garbage_classification
DATA_PROCESSED_DIR=data/processed
DATA_SPLIT_SEED=42

# ── Model ───────────────────────────────────────────────
MODEL_BACKBONE=efficientnet_b0                    # efficientnet_b0 | convnext_tiny
MODEL_WEIGHTS=models/exported/waste-classifier-v1.pt
MODEL_DEVICE=auto                                 # auto | cpu | cuda:0

# ── Training ────────────────────────────────────────────
TRAIN_EPOCHS=50
TRAIN_BATCH_SIZE=32
TRAIN_LR=0.001
TRAIN_WARMUP_EPOCHS=5
TRAIN_EARLY_STOPPING_PATIENCE=10
TRAIN_SEED=42

# ── Deployment / API ────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_API_URL=http://localhost:8000
PREDICTION_LOG_DB=outputs/predictions.db
OUTPUT_DIR=outputs

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
